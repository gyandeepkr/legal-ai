{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "legalai-connected.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/legalai-connected.html",
      "dest": "/legalai-connected.html"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/index.js",
      "methods": ["GET", "POST", "OPTIONS"]
    },
    {
      "src": "/analyze",
      "dest": "/index.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/contact",
      "dest": "/index.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/health",
      "dest": "/index.js"
    }
  ]
}